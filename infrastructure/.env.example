# =============================================
# ApplyPilot — Environment Variables
# Copy to backend/.env and fill in values
# =============================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# Encryption (generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# OpenAI
OPENAI_API_KEY=sk-proj-...

# Telegram Bot
TELEGRAM_BOT_TOKEN=...

# Cloudflare R2
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=applypilot-docs

# Steel.dev (cloud browser)
STEEL_API_KEY=

# Sentry (optional)
SENTRY_DSN=

# App
DEBUG=false

# =============================================
# Frontend (.env.local)
# =============================================
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_API_URL=https://your-backend.railway.app
# SUPABASE_SERVICE_KEY=  (backend use only)
