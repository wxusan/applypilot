# ─── Supabase ───────────────────────────────────────────────────────────────
# Found at: https://app.supabase.com/project/<id>/settings/api
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhb...          # service_role key (never expose client-side)
SUPABASE_ANON_KEY=eyJhb...             # anon/public key
SUPABASE_JWT_SECRET=your-jwt-secret    # Settings → API → JWT Secret

# ─── Encryption ─────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=

# ─── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Telegram Bot ───────────────────────────────────────────────────────────
# Create a bot via @BotFather → /newbot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklmNOPQRstuvWXYZ

# ─── Cloudflare R2 ──────────────────────────────────────────────────────────
# R2 → your bucket → Settings → Access Keys
CLOUDFLARE_R2_ACCOUNT_ID=abc123def456
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_BUCKET_NAME=applypilot-docs

# ─── Steel.dev (Browser Agent) ──────────────────────────────────────────────
# https://app.steel.dev → API Keys
STEEL_API_KEY=sk_steel_...

# ─── Sentry (optional) ──────────────────────────────────────────────────────
# https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=

# ─── App Config ─────────────────────────────────────────────────────────────
DEBUG=false
DASHBOARD_URL=https://app.applypilot.co
FRONTEND_URL=https://app.applypilot.co

# CORS — comma-separated allowed origins
# In production, only your Vercel deployment URL
CORS_ORIGINS=["https://app.applypilot.co"]

# ─── Cloudflare R2 Public URL (optional) ────────────────────────────────────
# If your R2 bucket is public or you have a custom domain pointing to it,
# set this to serve stable (non-expiring) URLs for uploaded files.
# Examples:
#   https://pub-xxxxxxxxxxxx.r2.dev         (R2 public dev URL)
#   https://cdn.applypilot.co               (custom domain)
# Leave empty to use 7-day presigned URLs instead (secure, works out of the box).
R2_PUBLIC_URL=
