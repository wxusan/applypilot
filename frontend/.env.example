# ─── Supabase (public — safe to expose in browser) ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhb...

# ─── Supabase (server-side only — NEVER expose in browser) ───────────────────
# Found at: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_KEY=eyJhb...

# ─── Site URL (CRITICAL) ──────────────────────────────────────────────────────
# Must match your production domain exactly.
# Used to build password-reset and invite links in /api/auth/forgot-password.
# If missing, links in emails will point to http://localhost:3000 in production!
# Local dev:   http://localhost:3000
# Production:  https://app.applypilot.co   (or your Vercel domain)
NEXT_PUBLIC_SITE_URL=https://app.applypilot.co

# ─── Backend API URL ──────────────────────────────────────────────────────────
# Leave empty for production — API calls are proxied through Next.js rewrites.
# The actual backend URL is set via BACKEND_URL (server-side only).
# Local dev: http://localhost:8000
NEXT_PUBLIC_API_URL=
BACKEND_URL=https://applypilot-backend.up.railway.app

# ─── Gmail SMTP (for forgot-password / reset emails from the frontend) ────────
# How to get an App Password:
#   Google Account → Security → 2-Step Verification → App Passwords
#   Name it "ApplyPilot" → copy the 16-char password (no spaces)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Telegram Bot (optional — sends reset link via Telegram if user linked) ───
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklmNOPQRstuvWXYZ
