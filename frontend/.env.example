# ApplyPilot Frontend — Environment Variables
# Copy this file to .env.local and fill in the values

# ── Supabase ────────────────────────────────────────────────────────────────
# Your project URL from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon (public) key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to client, server-side only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Backend API ─────────────────────────────────────────────────────────────
# URL of the FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Optional ────────────────────────────────────────────────────────────────
# Set to "true" to enable verbose logging
NEXT_PUBLIC_DEBUG=false
